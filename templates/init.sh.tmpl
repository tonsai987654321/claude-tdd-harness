#!/bin/bash
# The single command that answers: is this repo healthy, and is the harness still enforcing anything?
# Run it before editing, and again before claiming anything is done.
#
# Nothing about which projects exist or which paths are guarded is written here — it is all
# derived from .claude/harness.json at runtime, so widening the guarded set widens this check too.
set -euo pipefail

cd "$(dirname "$0")"
# The gate is handed file paths by Claude Code, which are native (`D:\...` on Windows).
# Under Git Bash `$PWD` is `/d/...`, which Windows Python resolves to a nonexistent
# `D:\d\...`: the gate finds no harness root and exits 0 — it fails OPEN, and the
# self-test below reads a healthy gate as a broken one. `pwd -W` prints the native path
# there. Test its OUTPUT, never its exit status: Linux bash accepts `-W`, prints nothing,
# and still exits 0, so keying off `||` would leave ROOT empty and fail open on POSIX.
ROOT="$(pwd -W 2>/dev/null)" || true
[ -n "$ROOT" ] || ROOT="$PWD"
export CLAUDE_PROJECT_DIR="$ROOT"
H=".claude/scripts/harness.py"

# --gate-only  everything that proves the harness itself, and nothing that needs the project's
#              toolchain. Fast enough to run on every session start, which is the point: the
#              checks in here used to happen only when somebody remembered.
# --quiet      say nothing while passing. A session-start hook that narrates a healthy repo
#              teaches people to skip its output, and then it cannot warn them.
GATE_ONLY=0
QUIET=0
for arg in "$@"; do
  case "$arg" in
    --gate-only) GATE_ONLY=1 ;;
    --quiet)     QUIET=1 ;;
    *) echo "usage: ./init.sh [--gate-only] [--quiet]" >&2; exit 2 ;;
  esac
done

ok() { [ "$QUIET" = 1 ] || printf "  ok   %s
" "$1"; }
say() { [ "$QUIET" = 1 ] || echo "$@"; }

# The verdict this run reaches, written wherever it stops. The gate reads it and refuses guarded
# writes while it says the harness is broken — a self-test whose result nothing consults is a
# report, and this repo has a lesson about numbers that only get quoted (docs/lessons/0011).
GATE_VERIFIED=0
write_verdict() {
  code=$?
  mkdir -p "$ROOT/.claude/state" 2>/dev/null || true
  printf '{"gate_verified": %s, "at": %s, "exit": %s}
'     "$([ "$GATE_VERIFIED" = 1 ] && echo true || echo false)"     "$(date +%s)" "$code" > "$ROOT/.claude/state/.selftest.json" 2>/dev/null || true
  exit $code
}
trap write_verdict EXIT

need() {
  command -v "$1" >/dev/null 2>&1 || { echo "MISSING: $1 — $2"; exit 1; }
  ok "$1"
}

hint_for() {
  case "$1" in
    python3) echo "Python 3.12+ — https://www.python.org/downloads/" ;;
    uv)      echo "https://docs.astral.sh/uv/getting-started/installation/" ;;
    docker)  echo "https://docs.docker.com/get-started/get-docker/" ;;
    gh)      echo "https://cli.github.com/" ;;
    node|npm) echo "Node 20+ — https://nodejs.org/en/download" ;;
    *)       echo "required by .claude/harness.json" ;;
  esac
}

# The harness's own prerequisite, and nothing else. It is hardcoded rather than read from
# `requires` because the gate self-test below is the one thing this script exists to prove, and it
# must not be reachable only on a machine that also happens to have Docker running. The project's
# tools are checked further down, next to the suites that need them.
#
# uv is the single one, even for a repo with no Python in it: it runs the harness's OWN suite in an
# isolated 3.12 environment, and it supplies Python when the machine has none. Everything else the
# harness needs follows from it, which is why this is the only thing offered for installation —
# docker, gh and node belong to the project, need a daemon or a login, and are the user's to choose.
uv_installer() {
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*) echo 'powershell -ExecutionPolicy ByPass -c "irm https://astral.sh/uv/install.ps1 | iex"' ;;
    *)                    echo 'curl -LsSf https://astral.sh/uv/install.sh | sh' ;;
  esac
}

ensure_uv() {
  command -v uv >/dev/null 2>&1 && { ok "uv"; return 0; }

  cmd="$(uv_installer)"
  echo "MISSING: uv — the harness runs its own suite through it, and gets Python from it."
  echo "         $(hint_for uv)"

  # Never install without being asked, and never hang waiting to ask. A non-interactive run — CI,
  # a headless agent, anything piping this script — gets the command and a failure, because
  # silently changing the machine is not a thing a verification script may do.
  if [ ! -t 0 ]; then
    echo "  Not an interactive terminal, so nothing was installed. Run this, then ./init.sh again:"
    echo "      $cmd"
    exit 1
  fi

  printf "  Install uv now? [y/N] "
  read -r reply || reply=""
  case "$reply" in
    [yY]*) ;;
    *) echo "  Declined. Run this, then ./init.sh again:"; echo "      $cmd"; exit 1 ;;
  esac

  eval "$cmd" || { echo "  The installer failed. Install uv by hand, then re-run ./init.sh."; exit 1; }

  # The installer drops uv in ~/.local/bin, which this shell will not have on PATH yet. Add it for
  # the rest of this run, then confirm by actually finding the binary — an installer's exit code
  # says the download worked, not that the tool is now runnable.
  PATH="$HOME/.local/bin:$PATH"
  export PATH
  command -v uv >/dev/null 2>&1 || {
    echo "  uv installed but is not on PATH in this shell. Open a new terminal and re-run ./init.sh."
    exit 1
  }
  ok "uv (just installed)"
}

say "=== Harness prerequisites ==="
ensure_uv

# Everything below runs Python through $PY. Where the machine has a python3 that is the fastest
# path; where it does not, uv fetches 3.12 on demand and costs about ten milliseconds more. Naming
# `python3` unconditionally is what made a machine without one unable to run this script at all,
# even with uv sitting right there able to supply one.
if command -v python3 >/dev/null 2>&1; then
  PY="python3"
  ok "python3"
else
  PY="uv run --no-project --python 3.12 python"
  ok "python 3.12 (provided by uv)"
fi

say
say "=== Harness self-test ==="
# A gate that has quietly stopped blocking is the worst possible failure: everything
# looks green while the discipline it exists to enforce is gone. Prove it still bites.
#
# Probe a synthetic project, never a real one. A real project's gate is legitimately OPEN
# in the middle of a RED cycle, and this check must not read honest work as a broken gate.

# Probe through the command string that is actually wired into .claude/settings.json, not
# through a `python3 $H` of this script's own choosing. Those are different things: the hook runs
# in Claude Code's shell, where a `python3` that resolves here may not exist, and a gate whose
# interpreter is missing is a gate that never runs. Testing the wired command is the only way
# this self-test speaks about the gate the editor will actually fire.
GATE_CMD="$($PY - <<'PY'
import json, pathlib
cfg = {}
p = pathlib.Path(".claude/settings.json")
if p.is_file():
    try:
        cfg = json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass
for entry in cfg.get("hooks", {}).get("PreToolUse", []):
    for hook in entry.get("hooks", []):
        cmd = hook.get("command", "")
        if "harness.py" in cmd and cmd.rstrip().endswith("gate"):
            print(cmd)
            raise SystemExit(0)
print("MISSING")
PY
)"
if [ "$GATE_CMD" = "MISSING" ]; then
  # Not a skip. A repo with no PreToolUse gate hook has no gate at all, however healthy
  # harness.py looks in isolation.
  echo "FAIL: no PreToolUse gate hook found in .claude/settings.json — nothing is guarding this repo."
  echo "      Re-run the installer, or add the hook by hand (see docs/PLAYBOOK.md)."
  exit 1
fi
GATE_CMD="${GATE_CMD//\$CLAUDE_PROJECT_DIR/$ROOT}"
GATE_CMD="${GATE_CMD//\$\{CLAUDE_PROJECT_DIR\}/$ROOT}"

probe() { echo "{\"tool_input\":{\"file_path\":\"$ROOT/$1\"}}" | eval "$GATE_CMD" >/dev/null 2>&1; echo $?; }

# Every guarded path must block, and a representative unguarded one must not. Both lists are
# generated from the config, so a repo that guards `lib/` gets `lib/` probed without editing this.
while IFS='|' read -r path want label; do
  [ -n "$path" ] || continue
  got=$(probe "$path")
  if [ "$got" != "$want" ]; then
    echo "FAIL: gate returned $got, wanted $want — $label ($path)"
    exit 1
  fi
  ok "$label"
done <<EOF
$($PY - <<'PY'
import json, pathlib

cfg = {}
p = pathlib.Path(".claude/harness.json")
if p.is_file():
    try:
        cfg = json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        pass

pdir = cfg.get("projects_dir", "projects")
guarded = cfg.get("guarded", ["app/", "src/", "alembic/versions/", "alembic/env.py"])
base = f"{pdir}/__gatecheck__"

# A file that should be refused, per guarded entry. A directory entry gets a plausible source
# file under it; an exact filename is probed as itself.
SAMPLE = {"app/": "probe.py", "src/": "probe.ts", "alembic/versions/": "0001_x.py"}
rows = []
for entry in guarded:
    if entry.endswith("/"):
        rows.append((f"{base}/{entry}{SAMPLE.get(entry, 'probe.py')}", 2, f"gate blocks {entry} while SHUT"))
    else:
        rows.append((f"{base}/{entry}", 2, f"gate blocks {entry}"))

# Things that must stay writable. Tests are the point of the exercise; config no test can
# drive must never be held hostage to a RED cycle.
rows += [
    (f"{base}/tests/test_probe.py", 0, "gate allows tests/"),
    (f"{base}/README.md", 0, "gate allows docs"),
]

# The harness's own machinery, refused whatever the gate says. Probed from the config so that
# widening `protected` widens this check too — and probed at all because the hole it closes was
# invisible: gate state is gitignored, so opening the gate by hand left no trace anywhere.
for entry in cfg.get("protected", [".claude/state/", ".claude/scripts/", ".claude/settings.json"]):
    sample = f"{entry}probe.json" if entry.endswith("/") else entry
    rows.append((sample, 2, f"gate refuses {entry} — the harness itself"))
if "alembic/env.py" in guarded:
    rows.append((f"{base}/alembic.ini", 0, "gate allows alembic config"))
if "src/" in guarded:
    rows.append((f"{base}/src/probe.test.ts", 0, "gate allows frontend tests under src/"))

# A worktree sits inside the harness root, so its project paths do not start at the projects
# dir. An anchored guard silently matches nothing there and the gate stops guarding entirely.
first_dir = next((g for g in guarded if g.endswith("/")), None)
if first_dir:
    sample = SAMPLE.get(first_dir, "probe.py")
    rows.append((f".claude/worktrees/__probe__/{base}/{first_dir}{sample}", 2,
                 f"gate blocks {first_dir} inside a worktree"))

for path, want, label in rows:
    print(f"{path}|{want}|{label}")
PY
)
EOF

$PY "$H" status >/dev/null
ok "dashboard renders"

# The suite under tests/ drives harness.py itself. It is pinned to 3.12 because it relies on
# EncodingWarning (3.10+) to prove the harness never falls back to the machine's locale codec --
# on an older interpreter the guard is ignored and every test would pass against broken code.
#
# Deliberately unconditional. The installer always writes this directory, so a missing suite is a
# broken install rather than a repo that happens not to have one — and a check that can skip
# itself is indistinguishable, in the output, from a check that passed. See docs/lessons/0002.
if [ ! -d "$ROOT/.claude/harness-tests" ]; then
  echo "FAIL: .claude/harness-tests/ is missing — the harness's own suite was never installed."
  echo "      Re-run /harness-init; the gate above is unverified without it."
  exit 1
fi
if uv run --no-project --python 3.12 --with pytest pytest "$ROOT/.claude/harness-tests" -q >/dev/null 2>&1; then
  ok "harness suite passes"
else
  echo "FAIL: the harness's own test suite is red. Run:"
  echo "      uv run --no-project --python 3.12 --with pytest pytest .claude/harness-tests -q"
  exit 1
fi

say
say "=== Unproven completions ==="
export HARNESS_QUIET="$([ "$QUIET" = 1 ] && echo 1 || echo "")"
$PY - <<'PY'
import json, os, pathlib, sys
bad, under = [], []
state_dir = pathlib.Path(".claude/state")
# Dotfiles are the harness's own bookkeeping — .selftest.json lives here too — and they carry no
# project. Globbing them as state made this scan die on a KeyError the moment the verdict file
# existed, which is to say the moment the check that writes it started working.
state_files = sorted(f for f in state_dir.glob("*.json") if not f.name.startswith(".")) if state_dir.is_dir() else []
for f in state_files:
    s = json.loads(f.read_text(encoding="utf-8"))
    project = s["project"]
    bad += [
        f"{project} cycle {c['id']}"
        for c in s["cycles"]
        if c["state"] == "done" and not c.get("evidence")
    ]
    # `cycle ... done` now refuses below the gate, but state written before that could not have
    # been refused. A repo carrying such a cycle should hear about it once, here.
    cyc = pathlib.Path(f".claude/cycles/{project}.json")
    gate = json.loads(cyc.read_text(encoding="utf-8")).get("coverage_gate") if cyc.is_file() else None
    cov = s.get("coverage")
    if gate is not None and cov is not None and cov < gate and any(c["state"] == "done" for c in s["cycles"]):
        under.append(f"{project} at {cov}% (gate {gate}%)")

if bad:
    print("  FAIL: marked done with no evidence: " + ", ".join(bad))
    print("        Re-verify and record evidence, or reopen the cycle.")
    sys.exit(1)
if under:
    print("  FAIL: done cycles under the coverage gate: " + ", ".join(under))
    print("        Cover the gap and re-run green, or change the gate deliberately.")
    sys.exit(1)
if not os.environ.get("HARNESS_QUIET"):
    print("  ok   every done cycle carries evidence and meets its coverage gate")
PY

# The machinery, checked against what was committed. The gate only ever sees Write and Edit, so a
# shell command reaches .claude/scripts/ and .claude/settings.json without any hook firing — but
# both are committed, and git remembers. No shell parsing, no guessing at intent: either the files
# match HEAD or they do not.
#
# Three outcomes, and the middle one is why this is not a skip. Tamper-evidence needs a reference;
# with no git history there is nothing to compare against, so the property simply does not exist
# here and saying so is the honest report. It is printed even under --quiet, because "unverifiable"
# is not the same as "fine".
if [ ! -d "$ROOT/.git" ]; then
  echo "  !!   this repo is not under git, so the harness machinery cannot be compared to anything."
  echo "         Shell writes to .claude/scripts/ would go unnoticed."
elif ! git -C "$ROOT" rev-parse --verify -q HEAD >/dev/null 2>&1; then
  # `git init` with nothing committed yet. `git diff HEAD` dies on the missing revision, and the
  # first version of this read that death as a difference — failing the self-test on a repo whose
  # only crime was being new.
  echo "  !!   no commits yet, so there is nothing to compare the harness machinery against."
  echo "         Commit .claude/ to make tampering detectable."
elif ! git -C "$ROOT" diff --quiet HEAD -- .claude/scripts .claude/settings.json 2>/dev/null; then
  echo "FAIL: .claude/scripts/ or .claude/settings.json differs from the last commit."
  git -C "$ROOT" diff --stat HEAD -- .claude/scripts .claude/settings.json 2>/dev/null | sed 's/^/      /'
  echo "      The gate never sees shell writes, so this is how an edit there surfaces."
  echo "      If you changed them on purpose, commit it. If you did not, restore with:"
  echo "          git -C \"$ROOT\" checkout HEAD -- .claude/scripts .claude/settings.json"
  exit 1
else
  untracked="$(git -C "$ROOT" ls-files --others --exclude-standard -- .claude/scripts .claude/settings.json)"
  if [ -n "$untracked" ]; then
    echo "  !!   harness machinery is not committed yet, so nothing can be compared to it:"
    echo "$untracked" | sed 's/^/         /'
    echo "         Commit .claude/ to make tampering detectable."
  else
    ok "harness machinery matches its last commit"
  fi
fi

# Everything above this line is the harness proving itself: the wired gate refuses what it must,
# the dashboard renders, the vendored suite is green, and no cycle claims a completion it cannot
# support. Past this line is the project's own toolchain, which is not the harness's to vouch for.
GATE_VERIFIED=1
if [ "$GATE_ONLY" = 1 ]; then
  say
  say "=== Harness verified ==="
  exit 0
fi

say
say "=== Project tooling ==="
# `requires` from .claude/harness.json — the tools the project suites need, checked here rather
# than at the top of the script. A missing Docker daemon is a real failure for a repo whose tests
# are containerised, but it says nothing about the gate, and it must never be able to abort the
# run before the self-test above has spoken.
for tool in $($PY -c '
import json, pathlib
cfg = {}
p = pathlib.Path(".claude/harness.json")
if p.is_file():
    try: cfg = json.loads(p.read_text(encoding="utf-8"))
    except Exception: pass
print(" ".join(t for t in cfg.get("requires", ["python3", "uv"]) if t not in ("python3", "uv")))
'); do
  need "$tool" "$(hint_for "$tool")"
done

if $PY -c '
import json,pathlib,sys
p=pathlib.Path(".claude/harness.json")
cfg=json.loads(p.read_text(encoding="utf-8")) if p.is_file() else {}
sys.exit(0 if "docker" in cfg.get("requires",[]) else 1)'; then
  docker info >/dev/null 2>&1 || {
    echo "FAIL: the Docker daemon is not running."
    echo "      \"docker\" is in requires, so a project here expects it — its tests will fail at the first fixture."
    exit 1
  }
  ok "docker daemon"
fi

if $PY -c '
import json,pathlib,sys
p=pathlib.Path(".claude/harness.json")
cfg=json.loads(p.read_text(encoding="utf-8")) if p.is_file() else {}
sys.exit(0 if "gh" in cfg.get("requires",[]) else 1)'; then
  gh auth status >/dev/null 2>&1 || { echo "FAIL: gh is not authenticated. Run: gh auth login"; exit 1; }
  ok "gh authenticated"
fi

say
say "=== Project suites ==="
# One project per cycle file, each with the runner it declared. Nothing about which tools a
# project uses is written here: `harness.py quality` and `green` read the commands out of
# .claude/harness.json. Sniffing for pyproject.toml and package.json — which is what this loop
# used to do — meant a repo on poetry, go or cargo silently reported "not scaffolded yet" and
# never ran a single check.
PROJECTS_DIR="$($PY -c '
import json, pathlib
p = pathlib.Path(".claude/harness.json")
cfg = json.loads(p.read_text(encoding="utf-8")) if p.is_file() else {}
print(cfg.get("projects_dir", "projects"))
')"

found=0
for cyclefile in .claude/cycles/*.json; do
  [ -e "$cyclefile" ] || continue
  p="$(basename "$cyclefile" .json)"
  d="$PROJECTS_DIR/$p"
  if [ ! -d "$d" ]; then
    echo "  skip $p (not cloned into $PROJECTS_DIR/ yet)"
    continue
  fi
  found=1
  echo "--- $p"
  $PY "$H" quality "$p"
  # `suite`, not `green`: green shuts the gate on success, and running the health check in the
  # middle of a RED cycle must not close a gate that cycle legitimately opened.
  $PY "$H" suite "$p"
done
[ "$found" = "1" ] || echo "  nothing to run yet — link_projects.sh clones the project repos"

say
say "=== Verification complete ==="
say
echo "Next steps:"
echo "1. Read PROGRESS.md for the board, or run: $PY $H status"
echo "2. Take the next action in HANDOFF.md, or run: $PY $H handoff"
echo "3. Work ONE cycle. Never skip: later tests depend on earlier code."
echo "4. No production code without a failing test. The gate enforces this; do not bypass it."
echo "5. A cycle is done only with evidence: what ran, what it printed, the two commit SHAs."
